# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin user ID (used for server-side data fetches)
ADMIN_USER_ID=your-admin-user-id

# WCA OAuth (register at https://www.worldcubeassociation.org/oauth/applications/new)
WCA_CLIENT_ID=your-wca-client-id
WCA_CLIENT_SECRET=your-wca-client-secret
NEXT_PUBLIC_WCA_CLIENT_ID=your-wca-client-id
