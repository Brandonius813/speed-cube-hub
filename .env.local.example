# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin user ID (used for server-side data fetches)
ADMIN_USER_ID=your-admin-user-id

# WCA OAuth (register at https://www.worldcubeassociation.org/oauth/applications/new)
WCA_CLIENT_ID=your-wca-client-id
WCA_CLIENT_SECRET=your-wca-client-secret
NEXT_PUBLIC_WCA_CLIENT_ID=your-wca-client-id

# AI Import (Claude Haiku for parsing unknown timer formats)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Feedback email delivery
RESEND_API_KEY=your-resend-api-key
# Optional override. Defaults to brandon@speedcubehub.com when unset.
FEEDBACK_EMAIL_TO=your-feedback-inbox@example.com
# Optional override. Defaults to Speed Cube Hub <feedback@speedcubehub.com> when unset.
FEEDBACK_EMAIL_FROM="Speed Cube Hub <feedback@speedcubehub.com>"

# AdSense slot IDs (optional overrides; defaults are already wired in code)
NEXT_PUBLIC_ADSENSE_HOME_INLINE_SLOT=4601663636
NEXT_PUBLIC_ADSENSE_FEED_INLINE_SLOT=7327899325
NEXT_PUBLIC_ADSENSE_PROFILE_SIDEBAR_SLOT=4450454545
NEXT_PUBLIC_ADSENSE_LEADERBOARDS_SIDEBAR_SLOT=1828160635
